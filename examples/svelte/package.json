{
  "name": "@sld-kit-examples/svelte",
  "version": "0.0.1",
  "private": true,
  "description": "Example SvelteKit editor built on @sld-kit/core + @sld-kit/svelte (not published).",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && cp build/index.html build/404.html",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "echo \"no tests yet\" && exit 0"
  },
  "dependencies": {
    "@sld-kit/core": "workspace:*",
    "@sld-kit/svelte": "workspace:*",
    "bits-ui": "^0.22.0",
    "clsx": "^2.1.0",
    "lucide-svelte": "^0.483.0",
    "mode-watcher": "^0.3.1",
    "svelte-sonner": "^0.3.28",
    "tailwind-merge": "^2.3.0",
    "tailwind-variants": "^0.2.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "svelte": "^4.2.7",
    "svelte-check": "^3.6.0",
    "tailwindcss": "^3.3.6",
    "tslib": "^2.4.1",
    "typescript": "^5.7.2",
    "vite": "^5.0.3"
  }
}
